font-family = "Hack Nerd Font Mono"
font-thicken = true
theme = Cursor Dark
title = " "

cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true

quit-after-last-window-closed = true
confirm-close-surface = false
window-inherit-working-directory = true
window-inherit-font-size = true
clipboard-trim-trailing-spaces = true

macos-icon = blueprint
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = hidden
mouse-hide-while-typing = true
font-size = 14

quick-terminal-animation-duration = 0
quick-terminal-screen = main

shell-integration-features = true

link-url = true

# Shader config (optional file — delete to disable shaders, recreate to enable)
config-file = ?shaders.conf

keybind = cmd+shift+space=toggle_quick_terminal
keybind = cmd+shift+comma=reload_config

keybind = super+ctrl+h=goto_split:left
keybind = super+ctrl+j=goto_split:down
keybind = super+ctrl+k=goto_split:up
keybind = super+ctrl+l=goto_split:right
